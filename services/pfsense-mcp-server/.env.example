# pfsense-mcp-server — environment variable contract for nvidia-ida deployment
#
# IMPORTANT: PFSENSE credentials (PFSENSE_USERNAME, PFSENSE_PASSWORD) and
# per-user MCP_API_KEY tokens are NEVER set here or in any git-tracked file.
# They are delivered exclusively via the Vault Agent Injector to a tmpfs mount
# at /vault/secrets/ inside the pod.  See platform/rhoai/base/pfsense-mcp-deployment.yaml
# for the Vault annotation template that renders those files.
#
# This file documents the env-var contract only.  Copy to .env for local dev
# and fill in real values (never commit the .env file).

# ── pfSense backend ───────────────────────────────────────────────────────────
PFSENSE_URL=https://172.99.0.1
PFSENSE_VERSION=CE_2_8_1
# Options: CE_2_8_0, CE_2_8_1, CE_26_03, PLUS_24_11, PLUS_25_11

# ── Authentication ────────────────────────────────────────────────────────────
# basic auth (admin user) — credentials injected by Vault Agent at runtime
AUTH_METHOD=basic
# PFSENSE_USERNAME=admin        # injected by Vault Agent to /vault/secrets/pfsense
# PFSENSE_PASSWORD=             # injected by Vault Agent to /vault/secrets/pfsense

# ── SSL ───────────────────────────────────────────────────────────────────────
# Set false for self-signed lab cert on pfSense
VERIFY_SSL=false

# ── MCP transport ─────────────────────────────────────────────────────────────
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=3000

# ── Bearer token auth (per-user tokens, comma-separated) ─────────────────────
# MCP_API_KEY is populated at runtime from /vault/secrets/mcp-tokens.
# The Vault Agent Injector renders the per-user token list from
# secret/data/mcp-tools/mcp-tokens into that file.
# ext-proc-delegation reads the calling user's token from Vault and injects it
# as the Authorization: Bearer header — the server validates it here.
#
# For local dev only (never commit real tokens):
# MCP_API_KEY=local-dev-token

# ── Read-only mode ────────────────────────────────────────────────────────────
# Set true to expose ONLY read (get_/search_/find_) tools.
# Default: false (write tools gated by guardrails + JIT approval layer).
MCP_READ_ONLY=false

# ── Tool allowlist (UC2 demo) ─────────────────────────────────────────────────
# Comma-separated list of tools permitted for non-read operations.
# get_* / search_* tools are always allowed regardless of this setting.
# create_firewall_rule_advanced is the single write operation for the UC2 demo.
MCP_ALLOWED_TOOLS=get_firewall_rules,get_interfaces,get_dhcp_leases,get_system_info,search_firewall_rules,search_aliases,create_firewall_rule_advanced

# ── Logging / audit ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# MCP_AUDIT_LOG=/logs/mcp-audit.jsonl

# ── Optional guardrail tuning ─────────────────────────────────────────────────
# MCP_RATE_LIMIT_DELETE=10
# MCP_RATE_LIMIT_CREATE=20
# MCP_RATE_LIMIT_CRITICAL=2
# MCP_ROLLBACK_BUFFER=50

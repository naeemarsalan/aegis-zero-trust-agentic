# Copy to environment/.env and fill in. NEVER commit .env (gitignored).
# Long-term home for these values is Vault — .env is bootstrap-only.

# AAP 2.6 (hammer cluster)
AAP_URL=https://aap-aap.apps.hammer.na-launch.com
AAP_USERNAME=
AAP_PASSWORD=

# Gitea (ArgoCD source, remediation PRs, JIT approval PRs)
GITEA_URL=https://git.arsalan.io
GITEA_USERNAME=
GITEA_PASSWORD=
GITEA_TOKEN=            # preferred over password — create in Gitea settings/applications

# Image registry
REGISTRY=oci.arsalan.io
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Existing observability
GRAFANA_URL=http://172.16.2.252:3000
GRAFANA_USERNAME=
GRAFANA_PASSWORD=
LOKI_PUSH_URL=http://172.16.2.252:3100

# pfSense (for the pfsense-mcp demo server; key moves to Vault after bootstrap)
PFSENSE_API_URL=
PFSENSE_API_KEY=

# Cluster access
ANAEEM_KUBECONFIG=~/.kube/anaeem-kubeconfig

# Platform endpoints (post-deploy)
VAULT_ADDR=https://vault.apps.anaeem.na-launch.com
KEYCLOAK_URL=https://keycloak.apps.anaeem.na-launch.com
MCP_GATEWAY_URL=https://mcp-gateway.apps.anaeem.na-launch.com
